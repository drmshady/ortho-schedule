    "eslint-plugin-react-refresh": "^0.4.11",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.4.0",
