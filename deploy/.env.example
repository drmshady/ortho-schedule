# Public domain served by Caddy. Example: clinic.example.com
DOMAIN=clinic.example.com

# PostgreSQL superuser password for the db container. Generate with: openssl rand -base64 24 | tr -d '/+=' | cut -c1-24
POSTGRES_PASSWORD=change-me-generate-with-openssl

# Async SQLAlchemy/PostgreSQL URL consumed by the backend and Alembic.
# Keep the password in sync with POSTGRES_PASSWORD.
DATABASE_URL=postgresql+psycopg://postgres:change-me-generate-with-openssl@db:5432/clinic

# Backend session signing secret. Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-generate-with-openssl-rand-base64-48

# Production cookies must be Secure because Caddy serves the app over HTTPS.
COOKIE_SECURE=true

# First-run super-admin bootstrap account. Replace before running seed_superadmin.
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-temporary-12-plus-chars

# Public age recipient used by deploy/ops/backup.sh for encrypted backups.
# Generate with: age-keygen -o /srv/clinic/backup-key.txt
BACKUP_AGE_RECIPIENT=age1replacewithpublicrecipientkey
